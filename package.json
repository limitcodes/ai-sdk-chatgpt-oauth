{
  "name": "ai-sdk-chatgpt-oauth",
  "version": "0.1.0",
  "description": "AI SDK provider for ChatGPT / OpenAI Codex OAuth",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["ai-sdk", "provider", "chatgpt", "oauth", "codex", "openai"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/openai": "^4.0.2",
    "@ai-sdk/provider": "^4.0.0",
    "@ai-sdk/provider-utils": "^5.0.1"
  },
  "peerDependencies": {
    "ai": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "ai": "^7.0.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
